---
const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios" },
  { label: "Planos Eléctricos", href: "/servicios/planos-electricos" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="header glass-panel">
  <div class="container header-container">
    <a href="/" class="logo text-gradient">
      <span class="logo-icon">⚡</span> Electrion Servicios Online
    </a>

    <button class="mobile-menu-toggle" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="desktop-nav">
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href="#cotizar" class="btn btn-primary">Cotizar Servicio</a>
    </nav>
  </div>
</header>

<style lang="scss">
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    border-radius: 0;
    border-left: none;
    border-right: none;
    border-top: none;
    border-bottom: 1px solid var(--border-color);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 2rem;

    ul {
      display: flex;
      gap: 1.5rem;
      list-style: none;

      .nav-link {
        font-weight: 500;
        font-size: 1rem;
        position: relative;
        padding: 4px 0;
        display: inline-block;

        &::after {
          content: "";
          position: absolute;
          bottom: 0;
          left: 0;
          width: 100%;
          height: 2px;
          background: var(--primary-color);
          transform: scaleX(0);
          transform-origin: right;
          transition: transform 0.3s ease;
        }

        &:hover {
          color: var(--primary-color);
          &::after {
            transform: scaleX(1);
            transform-origin: left;
          }
        }
      }
    }
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: transparent;
    border: none;
    cursor: pointer;

    span {
      width: 30px;
      height: 2px;
      background: var(--text-primary);
      transition: var(--transition);
    }
  }

  @media (max-width: 900px) {
    .desktop-nav {
      display: none;
    }
    .mobile-menu-toggle {
      display: flex;
    }
  }
</style>
