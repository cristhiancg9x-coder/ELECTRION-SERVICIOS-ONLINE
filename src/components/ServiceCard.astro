---
export interface Props {
	title: string;
	description: string;
	icon: string;
	href: string;
}

const { title, description, icon, href } = Astro.props;
---

<a href={href} class="service-card glass-panel group">
	<div class="card-icon">
		{icon}
	</div>
	<div class="card-content">
		<h3 class="card-title group-hover:text-primary transition">{title}</h3>
		<p class="card-desc">{description}</p>
	</div>
	<div class="card-arrow text-primary">
		→
	</div>
</a>

<style lang="scss">
	.service-card {
		position: relative;
		display: flex;
		flex-direction: column;
		padding: 2.5rem;
		text-decoration: none;
		color: inherit;
		transition: var(--transition);
		overflow: hidden;
		min-height: 320px;
		
		&:hover {
			transform: translateY(-5px);
			border-color: var(--primary-color);
			box-shadow: 4px 4px 0px 0px rgba(0, 85, 255, 0.15); /* Brutalist/Minimal sharp shadow */
			
			.card-title {
				color: var(--primary-color);
			}
			
			.card-arrow {
				transform: translateX(10px);
				opacity: 1;
			}
		}
	}
	
	.card-icon {
		font-size: 3rem;
		margin-bottom: 2rem;
		position: relative;
		z-index: 1;
	}
	
	.card-content {
		position: relative;
		z-index: 1;
		flex-grow: 1;
	}
	
	.card-title {
		font-size: 1.5rem;
		margin-bottom: 1rem;
		transition: var(--transition);
	}
	
	.card-desc {
		color: var(--text-secondary);
		line-height: 1.6;
	}
	
	.card-arrow {
		position: absolute;
		bottom: 2.5rem;
		right: 2.5rem;
		font-size: 1.5rem;
		font-weight: bold;
		color: var(--primary-color);
		opacity: 0.5;
		transition: var(--transition);
		z-index: 1;
	}
</style>
