---
import '../styles/global.scss';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

export interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = '/default-og.png' } = Astro.props;
const siteData = {
	siteName: "Electrion Servicios Online",
	url: Astro.site || Astro.url?.origin || "https://electrion-servicios-online.com",
};
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title} | {siteData.siteName}</title>
		<meta name="title" content={`${title} | ${siteData.siteName}`} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#ffffff" /> <!-- Updated to match light theme -->
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site || siteData.url)} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | ${siteData.siteName}`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site || siteData.url)} />
		<meta property="og:site_name" content={siteData.siteName} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={`${title} | ${siteData.siteName}`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.site || siteData.url)} />

		<!-- JSON-LD for WebSite and LocalBusiness -->
		<script type="application/ld+json" set:html={JSON.stringify([
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": siteData.siteName,
				"url": siteData.url,
				"description": "Expertos en servicios eléctricos en línea, diseño de planos, y diagramas unifilares para todo el mundo.",
				"inLanguage": "es"
			},
			{
				"@context": "https://schema.org",
				"@type": "ProfessionalService",
				"name": siteData.siteName,
				"image": new URL(image, Astro.site || siteData.url).toString(),
				"url": siteData.url,
				"telephone": "+51951413458",
				"priceRange": "$$",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Arequipa, Moquegua",
					"addressRegion": "Arequipa",
					"addressCountry": "PE",
					"description": "Servicios 100% en línea para todo el Perú y alcance a nivel global."
				},
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": -16.4090, 
					"longitude": -71.5375 
				},
				"description": "Servicios eléctricos en línea: planos, diagramas, presupuestos y asesoría técnica. Servicio remoto profesional.",
				"sameAs": [
					// Add social media links here in the future
				]
			}
		])} />
	</head>
	<body>
		<slot />
		<FloatingWhatsApp />
	</body>
</html>
