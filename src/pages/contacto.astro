---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
	title="Contacto y Cotizaciones"
	description="Ponte en contacto con Electrion para solicitar la cotización de tu proyecto eléctrico. Respuesta rápida y sin compromiso."
>
	<Header />
	
	<main class="contact-page">
		<section class="container">
			<div class="contact-grid">
				
				<div class="contact-info">
					<h1 class="page-title">Hablemos de tu <span class="text-gradient">Proyecto</span></h1>
					<p class="contact-lead">Estamos listos para brindarte la mejor solución. Déjanos tus datos o contáctanos directamente por cualquiera de nuestros medios.</p>
					
					<div class="info-cards mt-12">
						<div class="info-card glass-panel">
							<div class="info-icon">📧</div>
							<div>
								<h3>Correo Electrónico</h3>
								<p>proyectos@electrion.com.mx</p>
							</div>
						</div>
						
						<div class="info-card glass-panel">
							<div class="info-icon">📱</div>
							<div>
								<h3>WhatsApp Directo</h3>
								<p>+52 (123) 456-7890</p>
							</div>
						</div>
						
						<div class="info-card glass-panel">
							<div class="info-icon">📍</div>
							<div>
								<h3>Ubicación Base</h3>
								<p>Monterrey, N.L. México<br/><small>(Servicio Remoto y Nacional)</small></p>
							</div>
						</div>
					</div>
				</div>

				<div class="contact-form-wrapper glass-panel">
					<h2>Solicitar Presupuesto</h2>
					<form class="contact-form">
						<div class="form-group">
							<label for="name">Nombre Completo</label>
							<input type="text" id="name" name="name" required placeholder="Ej. Juan Pérez" />
						</div>
						
						<div class="form-group">
							<label for="email">Correo Electrónico</label>
							<input type="email" id="email" name="email" required placeholder="tucorreo@empresa.com" />
						</div>

						<div class="form-group">
							<label for="service">Servicio de Interés</label>
							<select id="service" name="service">
								<option value="planos">Planos Eléctricos</option>
								<option value="diagramas">Diagramas y Presupuestos</option>
								<option value="asesoria">Asesoría Técnica</option>
								<option value="otro">Otro / Próximamente (Electrónica)</option>
							</select>
						</div>
						
						<div class="form-group">
							<label for="message">Detalles del Proyecto</label>
							<textarea id="message" name="message" rows="5" required placeholder="Describe brevemente lo que necesitas..."></textarea>
						</div>
						
						<button type="submit" class="btn btn-primary w-full">Enviar Solicitud ⚡</button>
					</form>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>

<style lang="scss">
	.contact-page {
		padding-top: 140px;
		padding-bottom: 6rem;
		min-height: 80vh;
		position: relative;
	}

	.page-title {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		line-height: 1.1;
	}

	.contact-lead {
		font-size: 1.25rem;
		color: var(--text-secondary);
		max-width: 500px;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 6rem;
		align-items: start;
	}
	
	.info-cards {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	
	.info-card {
		display: flex;
		align-items: center;
		padding: 1.5rem;
		gap: 1.5rem;
		
		.info-icon {
			font-size: 2.5rem;
		}
		
		h3 {
			margin-bottom: 0.25rem;
			font-size: 1.125rem;
			color: var(--text-primary);
		}
		
		p {
			color: var(--text-secondary);
			margin: 0;
		}
	}

	.contact-form-wrapper {
		padding: 3rem;
		border-top: 4px solid var(--primary-color);
		
		h2 {
			font-size: 2rem;
			margin-bottom: 2rem;
		}
	}
	
	.form-group {
		margin-bottom: 1.5rem;
		
		label {
			display: block;
			margin-bottom: 0.5rem;
			font-weight: 500;
			color: var(--text-primary);
		}
		
		input, select, textarea {
			width: 100%;
			padding: 0.875rem 1rem;
			background: var(--bg-color);
			border: 1px solid var(--border-color);
			border-radius: 8px;
			color: var(--text-primary);
			font-family: inherit;
			font-size: 1rem;
			transition: var(--transition);
			
			&:focus {
				outline: none;
				border-color: var(--primary-color);
				background: var(--bg-tertiary);
			}
			
			&::placeholder {
				color: var(--text-secondary);
			}
		}
		
		select {
			appearance: none;
			background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2300e5ff%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E");
			background-repeat: no-repeat;
			background-position: right 1rem top 50%;
			background-size: 0.65rem auto;
			
			option {
				background: var(--bg-color);
				color: var(--text-primary);
			}
		}
	}

	.w-full { width: 100%; }
	.mt-12 { margin-top: 3rem; }

	@media (max-width: 900px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		
		.contact-form-wrapper {
			padding: 2rem 1.5rem;
		}
	}
</style>

<script>
	// Simple script to pre-select service based on URL parameter
	document.addEventListener('DOMContentLoaded', () => {
		const urlParams = new URLSearchParams(window.location.search);
		const service = urlParams.get('servicio');
		if (service) {
			const select = document.getElementById('service') as HTMLSelectElement;
			if (select) {
				const options = Array.from(select.options);
				const matchedOption = options.find(opt => opt.value === service);
				if(matchedOption) {
				    select.value = service;
				}
			}
		}
	});
</script>
